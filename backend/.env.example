# Copy this file to .env and fill in your values

PORT=5000

# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/synapsis
#
# Azure PostgreSQL example (fill in later):
# DATABASE_URL=postgresql://user@host:password@host.postgres.database.azure.com:5432/synapsis?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/synapsis

# Secret key used to sign JWT tokens — use a long random string in production
JWT_SECRET=change_this_to_a_strong_secret
