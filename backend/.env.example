# Server
PORT=5000
# Deployed frontend origin allowed by CORS (defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=5432

# Auth
JWT_SECRET=your_jwt_secret
NEXTAUTH_SECRET=your_nextauth_secret

# Gemini (Google GenAI) - required for the AI chatbot / Study Notebook
GEMINI_API_KEY=your_gemini_api_key

# Optional local Ollama fallback (used only if Gemini is unavailable)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_MS=8000

# SMTP for registration email verification
# If SMTP_HOST is omitted, Gmail/Hotmail/Outlook/Yahoo provider defaults are inferred from SMTP_USER.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
